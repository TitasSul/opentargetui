{
  "name": "opentargetui",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source browser extension for structured UI feedback to coding agents.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm --filter @opentargetui/core build && pnpm -r typecheck",
    "test": "pnpm --filter @opentargetui/core build && pnpm -r test",
    "check:extension-dist": "node scripts/check-extension-dist.mjs",
    "dev:extension": "pnpm --filter @opentargetui/extension dev",
    "dev:server": "pnpm --filter @opentargetui/mcp-server dev",
    "server": "pnpm --filter @opentargetui/mcp-server start",
    "doctor": "pnpm --filter @opentargetui/mcp-server doctor"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.25.0"
}
